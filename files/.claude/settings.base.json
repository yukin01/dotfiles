{
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "EDITOR": "vim"
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh project item-add:*)",
      "Bash(gh project item-list:*)",
      "Bash(gh repo list:*)",
      "Bash(gh search:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git ls-remote:*)",
      "Bash(git push -u origin:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git status:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(tail:*)",
      "Bash(terraform fmt:*)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "plan"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -z \"$CMUX_BUNDLE_ID\" ] && afplay /System/Library/Sounds/Funk.aiff || true"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -z \"$CMUX_BUNDLE_ID\" ] && afplay /System/Library/Sounds/Funk.aiff || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "plugin-dev@claude-plugins-official": true
  },
  "language": "Japanese",
  "effortLevel": "high",
  "plansDirectory": "./.local/plans"
}
