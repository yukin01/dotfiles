{
  "app": {
    "appearance": "dark",
    "appIcon": "light",
    "warnBeforeQuit": true
  },
  "browser": {
    "openTerminalLinksInCmuxBrowser": false
  },
  "sidebarAppearance": {
    "tintOpacity": 0.18
  },
  "commands": [
    {
      "name": "dotfiles",
      "description": "Dotfiles workspace: nvim + lazygit + shell + claude x2",
      "workspace": {
        "cwd": "~/dotfiles",
        "layout": {
          "direction": "horizontal",
          "split": 0.55,
          "children": [
            {
              "direction": "vertical",
              "split": 0.7,
              "children": [
                {
                  "pane": {
                    "surfaces": [
                      { "type": "terminal", "name": "nvim", "command": "nvim" },
                      { "type": "terminal", "name": "lazygit", "command": "lazygit" }
                    ]
                  }
                },
                {
                  "pane": {
                    "surfaces": [
                      { "type": "terminal", "name": "shell" }
                    ]
                  }
                }
              ]
            },
            {
              "direction": "vertical",
              "split": 0.5,
              "children": [
                {
                  "pane": {
                    "surfaces": [
                      { "type": "terminal", "name": "claude", "command": "claude", "focus": true }
                    ]
                  }
                },
                {
                  "pane": {
                    "surfaces": [
                      { "type": "terminal", "name": "claude", "command": "claude", "focus": true }
                    ]
                  }
                }
              ]
            }
          ]
        }
      }
    }
  ]
}
